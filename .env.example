# Supabase (publica — OK en frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Scan boletas — usa OpenRouter (gratis) o Gemini directo (billing)
# Si VITE_GEMINI_API_KEY tiene valor, usa Gemini directo
# Si no, usa OpenRouter como fallback
VITE_GEMINI_API_KEY=
VITE_OPENROUTER_API_KEY=

# Solo Edge Functions — NUNCA en el frontend
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
KHIPU_RECEIVER_ID=
KHIPU_SECRET=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
VITE_APP_URL=https://kuenta.vercel.app
VITE_FREEMIUM_ENABLED=false
